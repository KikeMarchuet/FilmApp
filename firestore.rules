rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    function currentUser() {
      return get(/databases/$(database)/documents/usuarios/$(request.auth.uid));
    }

    match /usuarios/{userId} {
      allow read, write: if signedIn() && request.auth.uid == userId;
    }

    match /peliculas/{peliculaId} {
      allow read: if signedIn();
      allow create, update, delete: if signedIn();
    }

    match /peliculas_favoritas/{favoriteId} {
      allow read: if signedIn();
      allow create, update: if signedIn()
        && request.resource.data.usuario_id == currentUser().data.app_id;
      allow delete: if signedIn()
        && resource.data.usuario_id == currentUser().data.app_id;
    }

    match /opiniones/{opinionId} {
      allow read: if signedIn();
      allow create, update, delete: if signedIn();
    }
  }
}
